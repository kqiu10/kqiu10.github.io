---
import { menuLinks } from "@/site.config";

// hide the Home link when already on the home page
const links = menuLinks.filter((link) => !(link.path === "/" && Astro.url.pathname === "/"));
---

<header class="flex justify-end" id="main-header">
	<nav aria-label="Main" class="flex flex-wrap items-center gap-x-6 gap-y-2">
		{
			links.map((link) => (
				<a
					aria-current={Astro.url.pathname === link.path ? "page" : false}
					class="font-medium text-inherit underline-offset-2 hover:underline"
					href={link.path}
					rel={link.path.startsWith("http") ? "noreferrer" : undefined}
					target={link.path.startsWith("http") ? "_blank" : undefined}
				>
					{link.title}
				</a>
			))
		}
	</nav>
</header>
