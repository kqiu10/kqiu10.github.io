---
import { menuLinks } from "@/site.config";

const onHome = Astro.url.pathname === "/";
// hide the Home link when already on the home page
const links = menuLinks.filter((link) => !(link.path === "/" && onHome));
---

<header class="flex justify-end" id="main-header">
	<nav aria-label="Main" class="flex flex-wrap items-center gap-x-6 gap-y-2">
		{
			links.map((link) => (
				<a
					aria-current={Astro.url.pathname === link.path ? "page" : false}
					class:list={[
						"font-medium transition-colors duration-150 hover:text-[#6991ff]",
						// highlighted links pair addyosmani's base blue with the #6991ff
						// hover; the darker shade keeps contrast on light pages
						link.highlight
							? ["text-base", onHome ? "text-[#5badf0]" : "text-[#2f7cd6]"]
							: "text-inherit",
					]}
					href={link.path}
					rel={link.path.startsWith("http") ? "noreferrer" : undefined}
					target={link.path.startsWith("http") ? "_blank" : undefined}
				>
					{link.title}
				</a>
			))
		}
	</nav>
</header>
