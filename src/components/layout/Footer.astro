---
import { siteConfig } from "@/site.config";

const year = new Date().getFullYear();
---

<footer
	class="text-muted mt-auto flex w-full items-center justify-center pt-20 pb-4 text-center font-semibold sm:text-xs"
>
	<div>
		&copy; Copyright <span data-footer-year>{year}</span>{" "}{siteConfig.author}
	</div>
</footer>

<script>
	// keep the year current between rebuilds
	const yearEl = document.querySelector("[data-footer-year]");
	if (yearEl) yearEl.textContent = String(new Date().getFullYear());
</script>
