---
import type { CollectionEntry } from "astro:content";
import PostPreview from "@/components/blog/PostPreview.astro";
import { getAllPosts } from "@/data/post";
import PageLayout from "@/layouts/Base.astro";
import { collectionDateSort } from "@/utils/date";

const allPosts = await getAllPosts();
const allPostsByDate = allPosts.sort(collectionDateSort) as CollectionEntry<"post">[];

// Pinned Posts, set to a max of 5;
const MAX_PINNED_POSTS = 5;
const pinnedPosts = allPostsByDate
	.values()
	.filter((p) => p.data.pinned)
	.take(MAX_PINNED_POSTS)
	.toArray();

const latestPost = allPostsByDate[0];
---

<PageLayout meta={{ title: "Home" }}>
	<section class="hero-container" slot="hero">
		<div class="text-container">
			<h1 class="mb-6 text-2xl font-semibold text-white sm:text-3xl">Kan Qiu</h1>
			<p class="mb-6 text-lg font-semibold text-zinc-300 sm:text-xl">仰望星空，脚踏实地</p>
			<p class="mb-6 text-lg font-semibold text-zinc-300 sm:text-xl">
				Keep your eyes on the stars, and your feet on the ground.
			</p>
			<p class="mb-6 leading-relaxed">
				Kan Qiu is the CTO of{" "}
				<a class="cactus-link" href="https://leapbound.ai/" rel="noreferrer" target="_blank"
					>Leapbound.ai</a
				>.{" "}
				He was previously a senior software engineer at Meta and, before that, an engineer on Amazon’s
				DynamoDB team. A developer for 5+ years. An avid learner of some layers of AI — LLM inference
				optimization and agent harnesses. He explores a new engineering paradigm: automate whatever AI
				can already do, and pour human effort into making LLMs capable of more. He shares what he learns
				along the way, from work and study alike, and you can find his writing on the <a
					class="cactus-link"
					href="/blog/">blog</a
				>.
			</p>
		</div>
		{/* right grid column is reserved for a future image-container */}
	</section>
	{
		pinnedPosts.length > 0 && (
			<section class="mt-16">
				<h2 class="section-title">Featured Blogs</h2>
				<ul class="space-y-4" role="list">
					{pinnedPosts.map((p) => (
						<li class="grid gap-1 sm:grid-cols-[auto_1fr]">
							<PostPreview post={p} />
						</li>
					))}
				</ul>
			</section>
		)
	}
	{
		latestPost && (
			<section class="mt-16 flex items-start gap-6">
				<img
					alt=""
					class="h-18 w-18 shrink-0 rounded-full"
					height="72"
					src="/github-notebook.svg"
					width="72"
				/>
				<div>
					<h2 class="title mb-4 text-xl">Blog</h2>
					<p class="leading-relaxed">
						You can find my writing on my{" "}
						<a class="cactus-link" href="/blog/">
							blog
						</a>
						. My last post on here was:{" "}
						<a class="cactus-link" href={`/blog/${latestPost.id}/`}>
							{latestPost.data.title}
						</a>
					</p>
				</div>
			</section>
		)
	}
</PageLayout>
